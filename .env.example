# ===================================================
# КОНФИГУРАЦИЯ БОТА NAILSTORY
# Скопируйте этот файл в .env и заполните значения
# ===================================================

# Токен вашего Telegram-бота (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# URL вашего проекта Supabase
# Найти в: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Anon (публичный) ключ Supabase
# Найти в: Supabase Dashboard → Settings → API → anon public
SUPABASE_KEY=your_supabase_anon_key_here

# Telegram ID администраторов через запятую (без пробелов)
# Все ID из этого списка имеют доступ к /admin
# Узнать свой ID можно у бота @userinfobot
ADMIN_IDS=123456789,987654321

# Telegram ID владельца (главного администратора)
# Владелец может добавлять/удалять администраторов и передавать владение
# Если не указан — используется первый ID из ADMIN_IDS
OWNER_ID=123456789
